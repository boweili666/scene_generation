    over "head_base_link" (
        prepend apiSchemas = ["PhysxRigidBodyAPI"]
    )
    {
        string isaac:nameOverride (
            displayName = "Name Override"
            doc = "Name override for prim lookup in base name search"
        )
        bool physxRigidBody:disableGravity = 1
        token visibility = "inherited"
    }

    over "head_link1" (
        prepend apiSchemas = ["PhysxRigidBodyAPI"]
    )
    {
        string isaac:nameOverride (
            displayName = "Name Override"
            doc = "Name override for prim lookup in base name search"
        )
        bool physxRigidBody:disableGravity = 1
        token visibility = "inherited"

        over "collisions" (
            instanceable = false
        )
        {
            over "head_link1_convex_0"
            {
                over "mesh"
                {
                    bool physics:collisionEnabled = 0
                }
            }
        }

        over "visuals" (
            instanceable = false
        )
        {
            over "head_link1" (
                prepend apiSchemas = ["MaterialBindingAPI"]
            )
            {
                rel material:binding = None (
                    bindMaterialAs = "weakerThanDescendants"
                )

                over "mesh" (
                    prepend apiSchemas = ["MaterialBindingAPI"]
                )
                {
                    rel material:binding = </genie/Looks/material_1___Default> (
                        bindMaterialAs = "weakerThanDescendants"
                    )
                }
            }
        }
    }

